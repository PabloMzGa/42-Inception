FROM debian:12

# ---------------------------------------------------------
# 1. Instalar PHP-FPM y extensiones necesarias para WordPress
# ---------------------------------------------------------
# NOTA: He unido los apt-get en una sola capa para reducir espacio, incluyendo mariadb-client
RUN apt update && apt install -y \
    php8.2-fpm \
    php8.2-mysql \
    php8.2-curl \
    php8.2-xml \
    php8.2-zip \
    php8.2-gd \
    php8.2-mbstring \
    php8.2-exif \
    php8.2-fileinfo \
    php8.2-cli \
    php8.2-common \
    mariadb-client \
    curl \
    tar \
    && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------
# [AÑADIDO] 1.5. Instalar WP-CLI (Para la automatización de usuarios/temas)
# ---------------------------------------------------------
RUN curl -O https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar \
    && chmod +x wp-cli.phar \
    && mv wp-cli.phar /usr/local/bin/wp

# ---------------------------------------------------------
# 2. Descargar WordPress
# ---------------------------------------------------------
RUN curl -o /tmp/wordpress.tar.gz https://wordpress.org/latest.tar.gz \
    && tar -xzf /tmp/wordpress.tar.gz -C /tmp \
    && rm /tmp/wordpress.tar.gz

# ---------------------------------------------------------
# 3. Copiar WordPress al directorio web y asegurar PID de PHP
# ---------------------------------------------------------
# REQUISITO DEBIAN: php-fpm necesita que el directorio /run/php exista para guardar su archivo .pid,
# si no existe en la imagen limpia, crashea al arrancar en el Entrypoint.
RUN mkdir -p /var/www/html /run/php \
    && cp -r /tmp/wordpress/* /var/www/html \
    && chown -R www-data:www-data /var/www/html

# ---------------------------------------------------------
# 4. Copiar script de inicialización
# ---------------------------------------------------------
COPY tools/wp-init.sh /usr/local/bin/wp-init.sh
RUN chmod +x /usr/local/bin/wp-init.sh

# ---------------------------------------------------------
# 5. Copiar configuración de PHP-FPM (pool)
# ---------------------------------------------------------
COPY conf/www.conf /etc/php/8.2/fpm/pool.d/www.conf

# ---------------------------------------------------------
# 6. Exponer el socket/puerto de PHP-FPM (interno)
# ---------------------------------------------------------
EXPOSE 9000

# ---------------------------------------------------------
# 7. Ejecutar script de inicialización
# ---------------------------------------------------------
ENTRYPOINT ["/usr/local/bin/wp-init.sh"]
